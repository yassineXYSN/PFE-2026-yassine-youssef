# GPU performance tuning (tuned for RTX 5070 12GB + i7-14th gen)
# llama3.1:8b (Q4_K_M ~4.4GB) leaves 7.6GB free — much faster inference than 14b
# 3 parallel slots are fine with 7b; would need to drop to 1-2 for 14b without ctx reduction
QUIZ_LLM_MAX_CONCURRENT=3
# CV screening / AI matching LLM concurrency (shared with quiz if both run simultaneously)
AI_MATCHING_MAX_CONCURRENT=3
# nomic-embed-text is tiny (~500MB), 12 concurrent is fine
QUIZ_EMBED_MAX_CONCURRENT=12
# Push all layers onto GPU
OLLAMA_NUM_GPU_LAYERS=99
# Context window per request — quiz prompts fit easily in 2048; halves KV cache vs 4096
OLLAMA_NUM_CTX=2048
# llama3.1:8b: ~4.4GB, ~2x faster than 14b, quality is fine for HR quiz questions
QUIZ_LLM_MODEL_LOCAL=qwen3:8b

USE_ATLAS_VECTOR_SEARCH=true
QUIZ_VECTOR_INDEX_NAME=quiz_chunks_vector_index



