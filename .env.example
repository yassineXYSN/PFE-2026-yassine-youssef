# ── Domains ──────────────────────────────────────────────────────────────────
# Frontend app URL (e.g. nexthire.itc4d.com)
APP_DOMAIN=nexthire.itc4d.com
# Backend API URL (e.g. api-nexthire.itc4d.com)
API_DOMAIN=api-nexthire.itc4d.com

# ── Backend runtime secrets ───────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/dbname
# Set to true only if you hit TLS errors with Atlas on this VPS
MONGODB_ATLAS_TLS_INSECURE=false

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-service-role-key
# Comma-separated list of allowed frontend origins; use * for open (dev only)
ALLOWED_ORIGINS=https://nexthire.itc4d.com

# ── Frontend build-time vars (baked into the JS bundle) ──────────────────────
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
