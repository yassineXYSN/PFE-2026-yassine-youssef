# ── Domains ───────────────────────────────────────────────────────────────────
APP_DOMAIN=nexthire.itc4d.com
API_DOMAIN=api-nexthire.itc4d.com

# ── Database ───────────────────────────────────────────────────────────────────
DB_USER=nexthire
DB_PASSWORD=change-this-strong-password
DB_NAME=nexthire
# Internal Docker URL (used by backend container to reach the db container)
DATABASE_URL=postgresql://nexthire:change-this-strong-password@nexthire-db:5432/nexthire

# ── Auth (JWT) ─────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key-in-production

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://nexthire.itc4d.com

# ── Frontend build-time vars (baked into the JS bundle) ───────────────────────
VITE_API_URL=https://api-nexthire.itc4d.com
