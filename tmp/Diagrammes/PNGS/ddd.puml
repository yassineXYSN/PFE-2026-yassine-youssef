@startuml
left to right direction
hide methods
hide circle
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam packageStyle rectangle

legend left
  ? = nullable / optional
  json = flexible Mongo subdocument / map
  Owning side = class storing the reference field
endlegend

note "Persisted MongoDB collections are modeled directly.\nDerived API-only fields are omitted.\nWhere runtime writes go beyond a declared Pydantic enum, the stored runtime shape wins." as N0

package "Org & Identity" {
  class "hr_companies" as hr_companies <<collection>> {
    _id: ObjectId {PK}
    name: str
    siret: str?
    domain: str?
    size: str?
    description: str?
    values: str[]?
    benefits: str[]?
    email: str?
    phone: str?
    contact_email: str?
    contact_phone: str?
    website: str?
    address: str?
    city: str?
    zip_code: str?
    country: str?
    latitude: float?
    longitude: float?
    logo_url: str?
    primary_color: str?
    linkedin: str?
    twitter: str?
    status: str
    onboarding_done: bool
    created_at: datetime
    updated_at: datetime
  }

  class "hr_departments" as hr_departments <<collection>> {
    _id: ObjectId {PK}
    name: str
    company_id: str
    description: str?
    manager_id: str?
    status: str
    color: str
    icon: str
    created_at: datetime
    updated_at: datetime
  }

  class "hr_profiles" as hr_profiles <<collection>> {
    _id: str {PK}
    first_name: str?
    last_name: str?
    email: str? {unique}
    role: str
    status: str
    company_id: str? {index}
    department_id: str?
    phone: str?
    position: str?
    avatar_url: str?
    bio: str?
    skills: json[]?
    experience: json[]?
    education: json[]?
    social_links: json?
    preferences: json?
    metadata: json?
    created_at: datetime
    updated_at: datetime
  }

  class "parametrage" as parametrage <<collection>> {
    _id: ObjectId {PK}
    company_id: str
    category: str
    parameters: json
    updated_at: str
    updated_by: str?
  }
}

package "Candidate" {
  class "candidates" as candidates <<collection>> {
    _id: ObjectId {PK}
    user_id: str {AK}
    email: str?
    firstName: str?
    lastName: str?
    birthDate: str?
    title: str?
    about: str?
    address: str?
    phone: str?
    linkedinUrl: str?
    github: str?
    twitter: str?
    website: str?
    profilePicture: str?
    profileImage: str?
    coverImage: str?
    cv: json?
    hobbies: Hobby[]
    skills: Skill[]
    languages: Language[]
    educations: Education[]
    experiences: Experience[]
    certificates: Certificate[]
    jobPreferences: JobPreferences?
    settings: json?
    settings_updated_at: datetime?
    preferences: json?
    ratings: CandidateRating[]?
    qualification_verifications: json?
    totp_secret: str?
    totp_enabled: bool?
    totp_verified_at: datetime?
    email_code: str?
    email_code_sent_at: datetime?
    email_2fa_enabled: bool?
    email_2fa_verified_at: datetime?
    embedding: float[]?
    profileStrength: int
    profileMissing: str[]
    created_at: datetime
    updated_at: datetime
  }

  class "saved_jobs" as saved_jobs <<collection>> {
    _id: ObjectId {PK}
    candidate_id: str
    job_id: str
    saved_at: datetime
  }

  class Hobby <<embedded>> {
    id: json?
    name: str?
  }

  class Skill <<embedded>> {
    id: json?
    name: str?
    level: json?
  }

  class Language <<embedded>> {
    id: json?
    name: str?
    level: json?
  }

  class Education <<embedded>> {
    id: json?
    degree: str?
    institution: str?
    fieldOfStudy: str?
    startYear: str?
    endYear: str?
    ongoing: bool?
    socialLink: str?
    certificateName: str?
    certificate: json?
  }

  class Experience <<embedded>> {
    id: json?
    jobTitle: str?
    company: str?
    type: str?
    position: str?
    startMonth: str?
    startYear: str?
    endMonth: str?
    endYear: str?
    ongoing: bool?
    description: str?
    documentName: str?
    document: json?
  }

  class Certificate <<embedded>> {
    id: json?
    name: str?
    issuer: str?
    issuingOrganization: str?
    year: str?
    issueDate: str?
    description: str?
    url: str?
    documentName: str?
    document: json?
  }

  class JobPreferences <<embedded>> {
    jobTypes: json
    workLocation: json
    salaryExpectation: str
    availability: str
    preferredIndustries: json
    willRelocate: json
  }

  class CandidateRating <<embedded>> {
    hr_id: str
    hr_email: str
    hr_name: str
    hr_role: str
    rate: int
    created_at: datetime
    updated_at: datetime
  }
}

package "Recruitment" {
  class AIAutomationFilter <<embedded>> {
    enabled: bool
    top_x_candidates: int?
    top_y_candidates: int?
  }

  class AIAutomationQuizConfig <<embedded>> {
    title: str
    document_id: str
    document_title: str
    total_questions: int
    duration_minutes: int
    weight_percentage: int
    difficulty_mix: json
    deadline_mode: str
    deadline_at: str
  }

  class AIAutomationQuizStage <<embedded>> {
    enabled: bool
    approve_top_z_to_interview: int?
    quizzes: AIAutomationQuizConfig[]
  }

  class AIAutomationConfig <<embedded>> {
    enabled: bool
    trigger_mode: str
    execution_enabled: bool
    vector_filter: AIAutomationFilter
    ai_score_filter: AIAutomationFilter
    quiz_stage: AIAutomationQuizStage
  }

  class "hr_jobs" as hr_jobs <<collection>> {
    _id: ObjectId {PK}
    title: str
    company_id: str {index}
    department_id: str?
    description: str
    requirements: str[]
    location: str?
    type: str
    status: str
    salary_range: str?
    missions: json?
    work_mode: str?
    experience_level: str?
    screening_questions: str[]
    deadline: str?
    notification_email: str?
    benefits: str[]
    require_motivation_letter: bool
    ai_automation: AIAutomationConfig?
    allow_hr: bool
    embedding: float[]?
    ai_automation_run_id: str?
    ai_automation_summary: json?
    deadline_processed: bool?
    deadline_processed_at: datetime?
    deadline_processing: bool?
    deadline_processing_started_at: datetime?
    deadline_last_error: str?
    deadline_last_error_at: datetime?
    quiz_stage_processed: bool?
    quiz_stage_processed_at: datetime?
    quiz_stage_processing: bool?
    quiz_stage_processing_started_at: datetime?
    quiz_stage_last_error: str?
    quiz_stage_last_error_at: datetime?
    created_at: datetime {index}
    updated_at: datetime
  }

  class "job_applications" as job_applications <<collection>> {
    _id: ObjectId {PK}
    candidate_id: str
    user_id: str?
    job_id: str
    motivation_letter: str?
    status: str
    profile_snapshot: json?
    applied_at: datetime
    updated_at: datetime?
    vector_match_score: float?
    vector_matched_at: datetime?
    ai_score: float?
    ai_justification: str?
    ai_evaluated_at: datetime?
    automation_run_id: str?
    automation_vector_rank: int?
    automation_ai_rank: int?
    automation_vector_score: float?
    automation_ai_score: float?
    automation_final_score: float?
    automation_interview_rank: int?
    automation_finalized_at: datetime?
    quiz_status: str?
    last_quiz_sent_at: datetime?
    quiz_score: float?
    quiz_attempts: int?
    quiz_completed_at: datetime?
    quiz_ai_analysis: str?
    quiz_ai_evaluated_at: datetime?
    interview_id: str?
    interview_proposal_id: str?
    interview_status: str?
    interview_start_time: datetime?
    interview_end_time: datetime?
  }

  class "candidat_applications" as candidat_applications <<legacy>> {
    _id: ObjectId {PK}
    candidate_id: str? {index}
    user_id: str?
    company_id: str? {index}
    job_id: str? {index}
    status: str?
    ai_score: float? {index}
    ai_justification: str?
    profile_snapshot: json?
    created_at: datetime? {index}
    updated_at: datetime?
  }
}

