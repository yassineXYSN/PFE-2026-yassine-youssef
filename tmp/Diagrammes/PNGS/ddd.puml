  class "hr_interviews" as hr_interviews <<collection>> {
    _id: ObjectId {PK}
    application_id: str?
    company_id: str
    recruiter_id: str?
    candidate_name: str
    candidate_email: str
    type: str
    start_time: datetime
    end_time: datetime
    status: str
