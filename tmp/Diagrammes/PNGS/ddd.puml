package "Quiz & Content" {
  class "fs.files" as fs_files <<system>> {
    _id: ObjectId {PK}
    filename: str
    length: long
    chunkSize: int
    uploadDate: datetime
    metadata: json?
  }

  class "fs.chunks" as fs_chunks <<system>> {
    _id: ObjectId {PK}
    files_id: ObjectId
    n: int
    data: binData
  }

  class SectionInfo <<embedded>> {
    title: str
    start_chunk: int
    end_chunk: int
  }

  class DocumentMetadata <<embedded>> {
    page_count: int?
    language: str?
    category: str?
  }

  class "quiz_documents" as quiz_documents <<collection>> {
    _id: ObjectId {PK}
    title: str
    filename: str
    file_type: str
    gridfs_file_id: str?
    uploaded_by: str
    company_id: str?
    uploaded_at: datetime
    status: str
    total_chunks: int
    total_tokens: int
    sections: SectionInfo[]
    metadata: DocumentMetadata
    extracted_text: str?
  }

  class "quiz_chunks" as quiz_chunks <<collection>> {
    _id: ObjectId {PK}
    document_id: ObjectId
    chunk_index: int
    text: str
    token_count: int
    section: str
    embedding: float[]?
    usage_count: int
    last_used_at: datetime?
    question_types_generated: str[]
    created_at: datetime
  }

  class QuizQuestion <<embedded>> {
    id: str
    type: str
    difficulty: str
    question: str
    options: str[]?
    correct_index: int?
    correct_answer: json?
    explanation: str
    source_chunks: str[]
    rubric: str?
  }

  class AnswerSubmission <<embedded>> {
    question_id: str
    answer: json
  }

  class "quizzes" as quizzes <<collection>> {
    _id: ObjectId {PK}
    title: str
    document_id: ObjectId?
    document_ids: ObjectId[]?
    multi_document: bool?
    template_id: ObjectId?
    generated_by: str
    company_id: str?
    application_id: str?
    candidate_id: str?
    generated_at: datetime
    updated_at: datetime?
    published_at: datetime?
    started_at: datetime?
    submitted_at: datetime?
    deadline: datetime?
    duration_minutes: int
    difficulty_distribution: json
    questions: QuizQuestion[]
    source_chunk_ids: str[]
    overlap_score: float?
    status: str
    score: float?
    candidate_answers: AnswerSubmission[]?
    ai_analysis: str?
    ai_analyzed_at: datetime?
    automation_run_id: str?
    automation_quiz_key: str?
    automation_job_id: str?
    auto_generated: bool?
    weight_percentage: int?
  }

  class QuestionTypeConfig <<embedded>> {
    count: int
    options_count: int?
  }

  class DistractorRules <<embedded>> {
    min_plausibility: str
    avoid_obvious_wrong: bool
  }

  class TemplateConfig <<embedded>> {
    total_questions: int
    question_types: QuestionTypeConfig[]
    difficulty_mix: json
    distractor_rules: DistractorRules
    sections_filter: str[]
    max_chunk_reuse: int
  }

  class "quiz_templates" as quiz_templates <<collection>> {
    _id: ObjectId {PK}
    name: str
    description: str
    created_by: str
    created_at: datetime
    config: TemplateConfig
  }

  class "quiz_audit" as quiz_audit <<collection>> {
    _id: ObjectId {PK}
    action: str
    user_id: str
    timestamp: datetime
    details: json
  }
}

candidates *-- "0..*" Hobby : hobbies
candidates *-- "0..*" Skill : skills
candidates *-- "0..*" Language : languages
candidates *-- "0..*" Education : educations
candidates *-- "0..*" Experience : experiences
candidates *-- "0..*" Certificate : certificates
candidates *-- "0..1" JobPreferences : jobPreferences
candidates *-- "0..*" CandidateRating : ratings

hr_jobs *-- "0..1" AIAutomationConfig : ai_automation
AIAutomationConfig *-- "1" AIAutomationFilter : vector_filter
AIAutomationConfig *-- "1" AIAutomationFilter : ai_score_filter
AIAutomationConfig *-- "1" AIAutomationQuizStage : quiz_stage
AIAutomationQuizStage *-- "0..*" AIAutomationQuizConfig : quizzes

quiz_documents *-- "0..*" SectionInfo : sections
quiz_documents *-- "1" DocumentMetadata : metadata
quizzes *-- "0..*" QuizQuestion : questions
quizzes *-- "0..*" AnswerSubmission : candidate_answers
quiz_templates *-- "1" TemplateConfig : config
TemplateConfig *-- "0..*" QuestionTypeConfig : question_types
TemplateConfig *-- "1" DistractorRules : distractor_rules

hr_departments "0..*" --> "1" hr_companies : company_id
hr_profiles "0..*" --> "0..1" hr_companies : company_id
hr_profiles "0..*" --> "0..1" hr_departments : department_id
parametrage "0..*" --> "1" hr_companies : company_id
parametrage "0..*" ..> "0..1" hr_profiles : updated_by

saved_jobs "0..*" --> "1" candidates : candidate_id
saved_jobs "0..*" --> "1" hr_jobs : job_id

job_applications "0..*" --> "1" candidates : candidate_id
job_applications "0..*" --> "1" hr_jobs : job_id
candidat_applications "0..*" --> "0..1" candidates : candidate_id/user_id
candidat_applications "0..*" --> "0..1" hr_jobs : job_id

hr_jobs "0..*" --> "1" hr_companies : company_id
hr_jobs "0..*" --> "0..1" hr_departments : department_id
AIAutomationQuizConfig "0..*" --> "1" quiz_documents : document_id

hr_interview_proposals "0..*" --> "1" job_applications : application_id
hr_interview_proposals "0..*" --> "0..1" hr_companies : company_id
hr_interview_proposals "0..*" --> "0..1" hr_profiles : recruiter_id
job_applications "0..*" --> "0..1" hr_interview_proposals : interview_proposal_id

hr_interviews "0..*" --> "0..1" job_applications : application_id
hr_interviews "0..*" --> "1" hr_companies : company_id
hr_interviews "0..*" --> "0..1" hr_profiles : recruiter_id
job_applications "0..*" --> "0..1" hr_interviews : interview_id

notifications "0..*" ..> "0..1" candidates : user_id (candidate)
notifications "0..*" ..> "0..1" hr_profiles : user_id (HR/admin)

fs_files o-- "0..*" fs_chunks : files_id
quiz_documents "0..*" --> "0..1" fs_files : gridfs_file_id

quiz_chunks "0..*" --> "1" quiz_documents : document_id
quizzes "0..*" --> "0..1" quiz_documents : document_id
quizzes "0..*" --> "0..*" quiz_documents : document_ids (multi_document)
quizzes "0..*" --> "0..1" quiz_templates : template_id
quizzes "0..*" --> "0..1" job_applications : application_id
quizzes "0..*" --> "0..1" candidates : candidate_id
quizzes "0..*" --> "0..*" quiz_chunks : source_chunk_ids / questions.source_chunks

quiz_audit "0..*" ..> "0..1" quizzes : details.quiz_id
quiz_audit "0..*" ..> "0..1" quiz_documents : details.document_id
quiz_audit "0..*" ..> "0..1" quiz_templates : details.template_id

note bottom of candidates
Most candidate relations use candidates.user_id, not candidates._id.
The collection also stores authentication/2FA fields and embeddings.
end note

note bottom of quizzes
Single-document quizzes use document_id.
Merged quizzes use document_ids + multi_document = true.
Runtime writes also persist status = completed.
end note

note bottom of hr_profiles
Google Calendar OAuth material is stored under
preferences.google_calendar.*.
end note

note bottom of quiz_documents
Raw uploaded binaries are stored in the default GridFS bucket
(fs.files / fs.chunks) and referenced by gridfs_file_id.
extracted_text is temporary and later unset after chunking.
end note

note bottom of candidat_applications
Legacy fallback collection.
Only a partial schema is visible in the repository.
end note

@enduml
