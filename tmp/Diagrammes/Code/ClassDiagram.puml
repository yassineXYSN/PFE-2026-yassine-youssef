@startuml ClassDiagram
!theme plain
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #2C3E50
skinparam classHeaderBackgroundColor #2C3E50
skinparam classHeaderFontColor #FFFFFF
skinparam classFontSize 11
skinparam ArrowColor #2C3E50
skinparam ArrowThickness 1.5
skinparam groupInheritance 2
skinparam linetype ortho

title HumatiQ — Class Diagram (Full)

' ─────────────────────────────────────────
'  AUTH / IDENTITY
' ─────────────────────────────────────────
package "Auth / Identity" #E8F4FD {

  class SupabaseUser {
    + id : UUID
    + email : str
    + role : str
    + created_at : datetime
    --
    + sign_in(email, password) : JWT
    + sign_out() : void
    + get_session() : Session
  }

  class JWTToken {
    + sub : str
    + email : str
    + session_id : str
    + role : str
    + iat : int
    + exp : int
    --
    + decode(secret) : Dict
    + is_expired() : bool
  }

  class AuthMiddleware {
    + security : HTTPBearer
    --
    + get_current_user(credentials) : Dict
    - _verify_with_supabase(token) : Dict
    - _decode_locally(token) : Dict
  }
}

' ─────────────────────────────────────────
'  CORE ENTITIES
' ─────────────────────────────────────────
package "Core Entities" #EBF5EB {

  class Profile {
