' ─────────────────────────────────────────
'  SERVICES
' ─────────────────────────────────────────
package "Services" #EAF2FF {

  class AIMatchingService {
    - db : AsyncIOMotorDatabase
    - http_client : httpx.AsyncClient
    --
    + find_top_candidates_for_job(description, limit) : List[Dict]
    + analyze_candidate_for_job(profile, job) : Dict
    + analyze_quiz_response(quiz, answers) : Dict
    + analyze_interview(interview, transcript) : Dict
    - _generate_embedding(text) : List[float]
    - _generate_with_llm(capability, prompt) : tuple
  }

  class JobAutomationService {
    + run_deadline_automation_for_job(job) : Dict
    + finalize_quiz_stage_for_job(job) : Dict
    - _filter_by_vector(job_id, top_x) : List
    - _rank_by_ai_score(applications, top_y) : List
    - _assign_quizzes(applications, config) : void
  }

  class GoogleCalendarService {
    - credentials : OAuth2Credentials
    --
    + create_event(title, start, end, attendees) : Dict
    + get_availability(date, duration) : List[Dict]
    + delete_event(event_id) : void
  }

  class NotificationService {
    + create(user_id, type, title, message) : Notification
    + send_email(to, subject, body) : void
    + mark_read(notif_id) : void
    + get_unread_count(user_id) : int
  }

  class InterviewScheduler {
    + check_reminders() : void
    + send_24h_reminder(interview) : void
    + send_1h_reminder(interview) : void
    + run_loop() : void
  }

  class CVParsingService {
    + parse_pdf(file_bytes) : Dict
    + parse_docx(file_bytes) : Dict
    + extract_skills(text) : List[str]
    + extract_experience(text) : List[Dict]
    + extract_education(text) : List[Dict]
  }

  class QuizIngestionService {
    + ingest_document(file, filename) : QuizDocument
    + chunk_and_store(doc_id, text) : List[QuizChunk]
    + embed_chunks(doc_id) : void
    + retrieve_chunks(doc_id, count) : List[QuizChunk]
    + generate_quiz(doc_id, config) : Quiz
    + validate_quiz(quiz) : bool
  }
}

' ─────────────────────────────────────────
'  RELATIONSHIPS
' ─────────────────────────────────────────

' Auth
SupabaseUser "1" -- "1" Profile : creates >
SupabaseUser "1" -- "0..1" CandidateProfile : creates >
AuthMiddleware ..> JWTToken : validates
AuthMiddleware ..> SupabaseUser : verifies with

' Company hierarchy
Company "1" *-- "0..*" Department : contains >
Company "1" *-- "0..*" Profile : employs >
Company "1" *-- "0..*" Job : posts >
Department "1" o-- "0..*" Profile : manages >
Department "1" o-- "0..*" Job : groups >

' Job relationships
Job "1" *-- "1" AIAutomationConfig : configured with >
AIAutomationConfig "1" *-- "1" QuizStageConfig : has >
Job "1" *-- "0..*" JobApplication : receives >
Job "1" -- "0..*" SavedJob : saved as >

' Application relationships
JobApplication "1" -- "0..1" Quiz : assigned >
JobApplication "1" -- "0..*" Notification : triggers >
CandidateProfile "1" *-- "0..*" JobApplication : submits >

' Quiz system
QuizDocument "1" *-- "0..*" QuizChunk : split into >
QuizDocument "1" *-- "0..*" Quiz : generates >
Quiz "1" *-- "1..*" QuizQuestion : contains >
Quiz "1" -- "0..*" QuizTemplate : based on >
QuizTemplate "1" *-- "1" TemplateConfig : configured by >
QuizQuestion -- QuestionType

' Interview
Interview "1" *-- "0..*" EmotionRecord : records >
Interview "1" *-- "0..*" TranscriptEntry : transcribes >
Interview "1" *-- "0..*" TimeSlot : proposes >
JobApplication "1" -- "0..1" Interview : leads to >

' Notifications
Profile "1" -- "0..*" Notification : receives >
CandidateProfile "1" -- "0..*" Notification : receives >

' Configuration
Company "1" -- "1" Parametrage : configures >
Parametrage "1" *-- "1" AIScoring : has >

' Services
AIMatchingService ..> CandidateProfile : analyzes
AIMatchingService ..> Job : matches for
AIMatchingService ..> QuizChunk : retrieves
JobAutomationService ..> JobApplication : updates
JobAutomationService ..> AIMatchingService : uses
JobAutomationService ..> NotificationService : triggers
InterviewScheduler ..> Interview : monitors
InterviewScheduler ..> NotificationService : triggers
QuizIngestionService ..> QuizDocument : creates
QuizIngestionService ..> QuizChunk : creates
QuizIngestionService ..> Quiz : generates
GoogleCalendarService ..> Interview : schedules
CVParsingService ..> CandidateProfile : populates

@enduml
