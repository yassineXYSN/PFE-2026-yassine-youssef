@startuml Seq_Interview
!theme plain
skinparam backgroundColor #FAFAFA
skinparam sequenceArrowThickness 1.5
skinparam sequenceGroupBorderColor #2980B9
skinparam noteBorderColor #F39C12
skinparam noteBackgroundColor #FEF9E7

title HumatiQ — Interview Scheduling & Execution Flow

actor Candidate
actor "HR / Recruiter" as HR
participant "React Frontend\n(InterviewRoom)" as FE
participant "FastAPI Backend" as BE
participant "WebSocket\n/ws/interviews/{id}" as WS
participant "GoogleCalendarService" as GCal
participant "InterviewScheduler\n(background loop)" as Sched
participant "NotificationService" as NS
participant "AIMatchingService" as AI
participant "Ollama / Claude LLM" as LLM
database "MongoDB\n(hr_interviews)" as Mongo
participant "SMTP / Email" as Mail

== HR Schedules Interview ==
HR -> FE : Go to Interviews > Create
FE -> BE : POST /api/interviews\n{ candidate_name, candidate_email,\n  type: "Video call", company_id }
BE -> Mongo : insert hr_interviews\n{ status: "pending" }
Mongo --> BE : interview_id
BE --> FE : { interview_id }

== HR Proposes Time Slots ==
HR -> FE : Propose available slots
FE -> BE : POST /api/interviews/{id}/propose-slots\n{ slots: [ {start, end}, {start, end} ] }
BE -> Mongo : update interview\n{ proposed_slots: [...] }
BE -> NS : notify candidate\n"Interview slots proposed"
NS -> Mongo : insert notification
NS -> Mail : Send email with slot options
BE --> FE : slots sent

== Candidate Confirms Slot ==
Candidate -> FE : View notification > Select slot
FE -> BE : POST /api/interviews/{id}/confirm-slot\n{ slot_index: 1 }
BE -> Mongo : update interview\n{ start_time, end_time,\n  status: "scheduled" }

== Google Calendar Event ==
BE -> GCal : create_event(\n  title="Interview: {candidate_name}",\n  start=start_time,\n  end=end_time,\n  attendees=[hr_email, candidate_email] )
GCal -> GCal : OAuth2 credentials check
GCal --> BE : { event_id, meet_link }
BE -> Mongo : update interview { calendar_event_id, meet_link }
BE -> NS : notify both parties\n"Interview confirmed + calendar event"
NS -> Mail : Confirmation emails with calendar link

== Interview Reminders (Scheduler Loop) ==
note over Sched : Runs every 60 seconds
loop Every 60s
  Sched -> Mongo : find scheduled interviews\nwhere reminder_24h_sent = false\nAND start_time ∈ [now+23h, now+25h]
  Mongo --> Sched : interviews[]
  loop For each interview
    Sched -> NS : send_24h_reminder(interview)
    NS -> Mail : "Your interview is in 24 hours"
    Sched -> Mongo : update { reminder_24h_sent: true }
  end

  Sched -> Mongo : find interviews\nwhere reminder_1h_sent = false\nAND start_time ∈ [now+50m, now+70m]
  Mongo --> Sched : interviews[]
  loop For each interview
    Sched -> NS : send_1h_reminder(interview)
    NS -> Mail : "Your interview starts in 1 hour"
    Sched -> Mongo : update { reminder_1h_sent: true }
  end
end

== Candidate & HR Join Interview Room ==
Candidate -> FE : Click interview link / join
HR -> FE : Join interview room

FE -> WS : WebSocket CONNECT\n/ws/interviews/{interview_id}
note right of WS
  WebRTC Signaling:
  - SDP offer/answer exchange
  - ICE candidate exchange
  - STUN/TURN negotiation
end note

FE -> FE : navigator.mediaDevices.getUserMedia()\n(camera + microphone)
FE -> FE : MediaPipe: load emotion model
FE -> FE : TensorFlow Lite: load face detector

== Video Interview in Progress ==
loop During interview
  FE -> FE : Capture video frames (every 2s)
  FE -> FE : Detect face landmarks (MediaPipe)
  FE -> FE : Classify emotion\n(neutral/happy/confused/stressed)
  FE -> BE : POST emotion record\n{ timestamp, emotion, confidence }
  BE -> Mongo : append to interview.emotion_history

  FE -> FE : Speech-to-text (Web Speech API)
  FE -> BE : POST transcript entry\n{ speaker, text, timestamp }
  BE -> Mongo : append to interview.transcript
end

== Post-Interview AI Analysis ==
HR -> FE : End interview
FE -> BE : PUT /api/interviews/{id}\n{ status: "completed" }
BE -> Mongo : update status

BE -> AI : analyze_interview(interview, transcript)
AI -> AI : Format transcript as structured text
AI -> LLM : POST /api/chat\n{ transcript + emotion_history\n  → evaluate communication,\n    confidence, technical depth,\n    emotion stability }
LLM --> AI : { overall_score, dimension_scores,\n  strengths, concerns, recommendation }
AI --> BE : ai_analysis dict

BE -> Mongo : update interview\n{ ai_analysis: {...},\n  status: "completed" }
BE --> FE : analysis results

FE -> HR : Display interview report:\n- Score breakdown\n- Emotion timeline chart\n- Transcript with highlights\n- AI recommendation

== HR Makes Final Decision ==
HR -> FE : View application + interview report
HR -> FE : Update application status
FE -> BE : PUT /api/applications/{id}\n{ status: "hired" or "rejected" }
BE -> Mongo : update application
BE -> NS : notify candidate of decision
NS -> Mail : Final decision email to candidate

@enduml
