@startuml Module_1_Partie_Candidat
skinparam backgroundColor #F8FAFC
skinparam defaultFontName Arial
skinparam nodesep 40
skinparam ranksep 60
left to right direction

actor "Candidat" as C

rectangle "1A. Module Candidat" {
  usecase "1.1 Crée un compte" as UC1_1
  usecase "1.2 S'authentifier via SSO" as UC1_2
  usecase "1.3 Se connecter" as UC1_3
  usecase "1.4 Réinitialiser le mot de passe oublié" as UC1_4
  usecase "1.5 Se déconnecter" as UC1_5
  
  usecase "1.6 Renseigner informations de base" as UC1_6
  usecase "1.7 Importer un CV / Document" as UC1_7
  usecase "1.8 Extraction automatique des données" as UC1_8
  usecase "1.9 Gérer ses expériences, formations, compétences" as UC1_9
  usecase "1.10 Gérer informations personnel " as UC1_12

  usecase "1.16 Paramètrage" as UC1_16
  usecase "1.17 Supprimer son compte" as UC1_17
}

C --> UC1_1
C --> UC1_2
C --> UC1_3
C --> UC1_4
C --> UC1_5

C --> UC1_6
C --> UC1_7
C --> UC1_9
C --> UC1_12
C --> UC1_16
C --> UC1_17

UC1_7 <.. UC1_8 : <<extend>>
UC1_7 <.. UC1_9 : <<extend>>

@enduml