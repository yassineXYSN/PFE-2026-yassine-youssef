@startuml Seq_QuizSystem
!theme plain
skinparam backgroundColor #FAFAFA
skinparam sequenceArrowThickness 1.5
skinparam sequenceGroupBorderColor #2980B9
skinparam noteBorderColor #F39C12
skinparam noteBackgroundColor #FEF9E7

title HumatiQ — Quiz Generation & Taking Flow

actor "HR / Recruiter" as HR
actor Candidate
participant "React Frontend" as FE
participant "FastAPI Backend\n/api/quiz" as BE
participant "QuizIngestionService" as QIS
participant "AIMatchingService" as AI
participant "Ollama\n(embed + generate)" as LLM
database "MongoDB\n(quiz_documents,\nquiz_chunks, quizzes)" as Mongo
database "GridFS\n(file storage)" as GridFS
participant "NotificationService" as NS

== HR Uploads Training Document ==
HR -> FE : Navigate to Quiz > Upload Document
FE -> HR : Show file upload interface
HR -> FE : Select PDF / DOCX / PPTX / image
FE -> BE : POST /api/quiz/upload-document\n(multipart/form-data: file, title)
BE -> GridFS : store raw file bytes
GridFS --> BE : gridfs_file_id
BE -> Mongo : insert quiz_documents\n{ title, filename, gridfs_file_id,\n  status: "processing", company_id }
Mongo --> BE : document_id
BE --> FE : 201 { document_id, status: "processing" }

== Document Ingestion (Background) ==
note over QIS : Async background task
BE -> QIS : ingest_document(file_bytes, filename)

alt PDF
  QIS -> QIS : PyPDF.extract_text()
else DOCX
  QIS -> QIS : python-docx.extract_text()
else Image
  QIS -> QIS : Tesseract OCR
end

QIS -> QIS : chunk_and_store(doc_id, text)
note right of QIS
  Sliding window:
  - chunk_size = 512 tokens
  - overlap = 64 tokens
  Store each chunk as QuizChunk
end note
QIS -> Mongo : bulk insert quiz_chunks\n{ doc_id, chunk_index, text, section }

== Embedding Generation ==
loop For each chunk
  QIS -> AI : _generate_embedding(chunk.text)
  AI -> LLM : POST /api/embeddings\n{ model: "nomic-embed-text",\n  prompt: chunk.text }
  LLM --> AI : float[] (768-dim)
  QIS -> Mongo : update quiz_chunks\n{ embedding: [...] }
end
QIS -> Mongo : update quiz_documents\n{ status: "ready", total_chunks }

== HR Creates Quiz Template (Optional) ==
HR -> FE : Configure quiz template
FE -> BE : POST /api/quiz/templates\n{ name, config: { total_questions: 20,\n  types: { mcq:60%, tf:20%, scenario:20% },\n  difficulty: { easy:30%, med:50%, hard:20% } } }
BE -> Mongo : insert quiz_templates
Mongo --> BE : template_id
BE --> FE : { template_id }

== HR Generates Quiz ==
HR -> FE : Select document + template → Generate
FE -> BE : POST /api/quiz/generate\n{ document_id, template_id, title }
BE -> QIS : generate_quiz(doc_id, config)

QIS -> Mongo : Vector search quiz_chunks\n(select top N diverse chunks)
Mongo --> QIS : relevant chunks[]

loop For each question batch
  QIS -> LLM : POST /api/chat\n{ prompt: chunk.text,\n  instruction: "Generate MCQ + TF + scenario" }
  LLM --> QIS : JSON { questions: [...] }
  QIS -> QIS : validate_quiz_output(questions)
  QIS -> QIS : check overlap_score < threshold
end

QIS -> Mongo : insert quizzes\n{ title, document_id, questions[],\n  status: "published" }
Mongo --> QIS : quiz_id
QIS --> BE : quiz_id

BE --> FE : { quiz_id, questions_count }
FE -> HR : "Quiz generated successfully"

== Quiz Assignment to Candidate (via Automation) ==
note over BE : Triggered by JobAutomationService
BE -> Mongo : link quiz to application\n{ application.quiz_id = quiz_id,\n  quiz_status: "draft" }
BE -> NS : create notification\n{ user_id: candidate_id,\n  category: "quiz",\n  title: "Quiz Ready",\n  link: "/quiz/{quiz_id}" }
NS -> Mongo : insert notification
NS --> Candidate : Email + in-app notification

== Candidate Takes Quiz ==
Candidate -> FE : Open quiz from notification
FE -> BE : GET /api/applications/{app_id}/quiz
BE -> Mongo : find quiz by application_id
Mongo --> BE : quiz { questions, duration_minutes }
BE -> Mongo : update application\n{ quiz_status: "in_progress",\n  started_at: now }
BE --> FE : quiz data (no correct_answers)

FE -> FE : Start countdown timer\n(duration_minutes)
FE -> Candidate : Display questions one by one

Candidate -> FE : Answer each question
FE -> FE : Store answers in state (no partial save)

note right of Candidate
  Question types:
  - MCQ: select option A/B/C/D
  - True/False: toggle
  - Scenario: text input
  - Fill-in: text input
end note

alt Timer expires OR Candidate submits
  FE -> BE : POST /api/applications/{app_id}/quiz/submit\n{ answers: [{ question_id, answer }] }

  == Auto-Grading ==
  BE -> AI : analyze_quiz_response(quiz, answers)
  AI -> AI : Compare MCQ/TF answers to correct_answer
  AI -> LLM : POST /api/chat\n{ scenario questions + answers → evaluate rubric }
  LLM --> AI : { score, feedback_per_question, weak_areas }
  AI --> BE : { total_score: 74.5, analysis: "..." }

  BE -> Mongo : update application\n{ quiz_status: "evaluated",\n  quiz_score: 74.5,\n  quiz_ai_analysis: "...",\n  quiz_completed_at: now }

  == Post-Quiz Decision ==
  alt quiz_score >= threshold
    BE -> Mongo : update application { status: "interview" }
    BE -> NS : notify candidate "You passed the quiz!"
    BE -> NS : notify HR "Candidate ready for interview"
  else quiz_score < threshold
    BE -> Mongo : update application { status: "rejected" }
    BE -> NS : notify candidate "Quiz result: not shortlisted"
  end

  NS -> Mongo : insert notifications
  BE --> FE : { score: 74.5, passed: true, feedback }
  FE -> Candidate : Show score + feedback report
end

== HR Reviews Quiz Results ==
HR -> FE : View application quiz tab
FE -> BE : GET /api/applications/{app_id}
BE -> Mongo : fetch application with quiz data
Mongo --> BE : { quiz_score, quiz_ai_analysis, answers }
BE --> FE : full application detail
FE -> HR : Display quiz score + AI analysis breakdown

@enduml
