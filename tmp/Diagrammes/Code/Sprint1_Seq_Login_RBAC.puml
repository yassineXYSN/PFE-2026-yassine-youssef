@startuml Sprint1_Seq_Login_RBAC
!theme plain
skinparam backgroundColor #FAFAFA
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #2C3E50
skinparam sequenceParticipantBackgroundColor #FFFFFF
skinparam sequenceActorBorderColor #2C3E50
skinparam sequenceLifeLineBorderColor #95A5A6
skinparam sequenceGroupBorderColor #2980B9
skinparam noteBorderColor #F39C12
skinparam noteBackgroundColor #FEF9E7
skinparam shadowing false
skinparam roundcorner 6
skinparam fontname "Segoe UI"

title Sprint 1 — Flux d'Authentification, Contrôle RBAC et Déconnexion

actor "Utilisateur\n(Candidat / RH / SuperAdmin)" as User
participant "React\nFrontend\n(Supabase SDK)" as FE
participant "Supabase\nAuth" as Supabase
database "Supabase DB\n(PostgreSQL)" as SupaDB
participant "FastAPI\nBackend" as BE
database "MongoDB\n(hr_profiles)" as Mongo

note over FE, Supabase
  La connexion est entièrement gérée entre le Frontend
  et Supabase via le SDK client — le Backend n'est pas impliqué.
end note

' ─────────────────────────────────────────
== Connexion (Login) ==
' ─────────────────────────────────────────

User -> FE : Saisit email + mot de passe
FE -> Supabase : signInWithPassword(email, password)
activate Supabase
Supabase -> SupaDB : Vérifie credentials (bcrypt)
SupaDB --> Supabase : user record
Supabase --> FE : JWT { sub, email, role, session_id, iat, exp }
deactivate Supabase

FE -> FE : Stocke JWT en mémoire

note right of FE
  Payload JWT :
  { sub, email, role,
    session_id, iat, exp }
end note

' ─────────────────────────────────────────
== Notification Post-Connexion ==
' ─────────────────────────────────────────

FE -> BE : POST /auth/notify-login\n         Authorization: Bearer <JWT>
activate BE
BE -> Supabase : get_user(token)
activate Supabase
Supabase --> BE : user { id, email }
deactivate Supabase
BE -> BE : Envoie email d'alerte (SMTP en arrière-plan)
note right of BE
  Email : "Nouvelle connexion
  détectée sur votre compte HumatiQ"
end note
BE --> FE : { status: "notification_sent" }
deactivate BE

FE -> User : Redirige vers /dashboard/{role}

' ─────────────────────────────────────────
== Requête API Authentifiée avec Contrôle RBAC ==
' ─────────────────────────────────────────

User -> FE : Effectue une action (ex. accéder à une ressource)
FE -> BE : GET /api/{ressource}\n         Authorization: Bearer <JWT>
activate BE

BE -> BE : 1. Décodage local du JWT (jose)\n    Vérification de l'expiration (exp)
BE -> Supabase : 2. get_user(token)\n   [retry ×4, backoff exponentiel]
activate Supabase
Supabase --> BE : user { id, email, user_metadata.role }
deactivate Supabase
BE -> Mongo : 3. find hr_profiles { _id: user.id }
activate Mongo
Mongo --> BE : { role, company_id, department_id }
deactivate Mongo
BE -> BE : 4. require_roles([...]) — contrôle RBAC\n    superadmin bypass toutes restrictions

alt Rôle autorisé
    BE -> Mongo : Query collection métier
    activate Mongo
    Mongo --> BE : Documents
    deactivate Mongo
    BE --> FE : 200 OK + données JSON
    FE -> User : Affiche la vue
else Rôle insuffisant
    BE --> FE : 403 Forbidden
    FE -> User : Affiche "Accès refusé"
else Token expiré / invalide
    BE --> FE : 401 Unauthorized
    FE -> Supabase : refreshSession()
    activate Supabase
    Supabase --> FE : Nouveau access_token
    deactivate Supabase
    FE -> BE : Relance la requête originale
end
deactivate BE

' ─────────────────────────────────────────
== Déconnexion ==
' ─────────────────────────────────────────

User -> FE : Clique sur Déconnecter
FE -> Supabase : signOut()
activate Supabase
Supabase --> FE : succès (session révoquée)
deactivate Supabase
FE -> FE : Efface le JWT local
FE -> User : Redirige vers /login

@enduml
