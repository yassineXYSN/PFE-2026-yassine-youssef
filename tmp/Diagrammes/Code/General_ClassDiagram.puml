@startuml
' --- Configuration Globale ---
!theme plain
skinparam shadowing false
skinparam roundcorner 8
skinparam fontname "Segoe UI"
skinparam TitleFontSize 20
skinparam TitleFontColor #2C3E50
skinparam nodesep 50
skinparam ranksep 50

' --- Style des Classes ---
skinparam class {
    BorderColor #34495E
    BackgroundColor #F4F7F9
    HeaderBackgroundColor #D6DBDF
    FontSize 12
    AttributeFontSize 11
}

' Style spécifique pour l'IA
skinparam class<<AI>> {
    BackgroundColor #F5EEF8
    BorderColor #8E44AD
    HeaderBackgroundColor #EBDEF0
}

' Style pour les Enums ou Types de support
skinparam class<<Support>> {
    BackgroundColor #FEF9E7
    BorderColor #F1C40F
}

title HumatiQ — Diagramme de Classes Général

package "Gestion des Utilisateurs" {
    class Utilisateur {
        +UUID id
        +String email
        +String role
        +DateTime dateCreation
        +seConnecter()
        +seDeconnecter()
    }

    class SuperAdministrateur {
        +gererEntreprises()
        +gererUtilisateurs()
        +voirStatsGlobales()
    }

    class AdminEntreprise {
        +String entrepriseId
        +onboardingEntreprise()
        +gererDepartements()
        +inviterMembresRH()
        +configurerIA()
    }

    class RecruteurRH {
        +String entrepriseId
        +String departementId
        +publierOffre()
        +examinerCandidatures()
        +planifierEntretiens()
        +genererQuiz()
    }

    class Candidat {
        +configurerProfil()
        +rechercherOffres()
        +postuler()
        +passerQuiz()
        +rejoindreEntretien()
    }

    Utilisateur <|-- SuperAdministrateur
    Utilisateur <|-- AdminEntreprise
    Utilisateur <|-- RecruteurRH
    Utilisateur <|-- Candidat
}

package "Structure Entreprise" {
    class Entreprise {
        +ObjectId id
        +String nom
        +String domaine
        +String statut
        +Boolean onboardingTermine
    }

    class Departement {
        +ObjectId id
        +String nom
        +String entrepriseId
        +String managerId
    }

    class ConfigurationIA {
        +int topXCandidats
        +int topYCandidats
        +int topZPourQuiz
        +float seuilSimilarite
    }

    Entreprise "1" *-- "1..*" Departement : contient
    Entreprise "1" *-- "1" ConfigurationIA : est configurée par
    AdminEntreprise "1" --> "1" Entreprise : gère
    RecruteurRH "1" --> "1" Departement : appartient à
}

package "Pipeline de Recrutement" {
    class OffreEmploi {
        +ObjectId id
        +String titre
        +String statut
        +DateTime dateEcheance
        +Boolean automatisationIA
    }

    class Candidature {
        +ObjectId id
        +String statut
        +float scoreSimilarite
        +float scoreIA
        +float scoreQuiz
    }

    class Quiz {
        +ObjectId id
        +List<Question> questions
        +int dureeMinutes
        +float scoreObtenu
    }

    class Entretien {
        +ObjectId id
        +DateTime programmeLe
        +String statut
        +Dict analyseIA
        +List donneesEmotions
    }

    Entreprise "1" *-- "0..*" OffreEmploi : publie
    Departement "1" o-- "0..*" OffreEmploi : regroupe
    OffreEmploi "1" *-- "0..*" Candidature : reçoit
    Candidat "1" *-- "0..*" Candidature : soumet
    Candidature "1" -- "0..1" Quiz : assigné
    Candidature "1" -- "0..1" Entretien : mène à
}

class MoteurIA <<AI>> {
    +faireCorrespondanceCandidats()
    +noterProfilCandidat()
    +genererQuestionsQuiz()
    +evaluerReponsesQuiz()
    +analyserEntretien()
}

class Notification <<Support>> {
    +ObjectId id
    +String utilisateurId
    +String categorie
    +String message
    +Boolean estLu
}

' ── Relations SuperAdministrateur (manquantes) ──────────────────
SuperAdministrateur "1" --> "0..*" Entreprise      : supervise
SuperAdministrateur "1" --> "0..*" AdminEntreprise : désigne

' Relations de dépendance du Moteur IA
MoteurIA ..> OffreEmploi : analyse
MoteurIA ..> Candidature : évalue
MoteurIA ..> Quiz        : génère & évalue
MoteurIA ..> Entretien   : analyse

Utilisateur "1" -- "0..*" Notification : reçoit
@enduml