@startuml Sprint3_Architecture
!theme plain
skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam componentStyle rectangle
skinparam linetype ortho
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #2C3E50
}
skinparam database {
  BackgroundColor #FEF9E7
  BorderColor #B7950B
}
skinparam queue {
  BackgroundColor #E8F8F5
  BorderColor #148F77
}

title HumatiQ — Sprint 3 : Architecture logique Quiz et IA

actor "Utilisateur RH" as HR
actor "Candidat" as CAND

rectangle "Frontend React" {
  component "Espace RH\nApplications, Offres, Quiz" as HRUI
  component "Espace Candidat\nQuiz, Find Jobs, Profil" as CANDUI
}

rectangle "Backend FastAPI" {
  component "Quiz Router\n/api/quiz/*" as QuizRouter
  component "AI Matching Router\n/api/ai-matching/*" as MatchingRouter
  component "Account Setup Router\n/api/candidat/account-setup/*" as AccountRouter
  component "Applications / Jobs Routers" as CoreRouters
  component "Quiz Services\nIngestion, Chunking, Retrieval, Generation" as QuizServices
  component "AIMatchingService\nEmbeddings, scoring, justification" as MatchingService
  component "JobAutomationService\nDeadline, top X/Y/Z, quiz assignment" as AutomationService
  component "Notification Service" as NotificationService
}

database "MongoDB Atlas" as Mongo {
  folder "Collections métier\njobs, applications, candidates" as M1
  folder "Collections quiz\nquiz_documents, quiz_chunks, quizzes" as M2
  folder "Vector Search Index\nembedding fields" as M3
}

database "GridFS\nDocuments importés" as GridFS
queue "Schedulers / Background Tasks" as BG
cloud "LLM configurable\nOllama par défaut\nHuggingFace/OpenAI optionnels\nMock en test" as LLM
cloud "Serveur Embeddings\nnomic-embed-text" as Embed
cloud "Supabase Auth\nJWT / sessions" as Auth

HR --> HRUI
CAND --> CANDUI
HRUI --> QuizRouter
HRUI --> MatchingRouter
HRUI --> CoreRouters
CANDUI --> QuizRouter
CANDUI --> AccountRouter
CANDUI --> CoreRouters

QuizRouter --> QuizServices
MatchingRouter --> MatchingService
AccountRouter --> MatchingService : vectorisation profil
CoreRouters --> Mongo

QuizServices --> GridFS : stocker fichier
QuizServices --> Mongo : documents, chunks, quizzes
QuizServices --> Embed : embeddings chunks
QuizServices --> LLM : génération questions

MatchingService --> Mongo : profils, offres, candidatures
MatchingService --> Embed : embeddings profil/offre
MatchingService --> Mongo : recherche vectorielle
MatchingService --> LLM : justification score

AutomationService --> MatchingService
AutomationService --> QuizServices
AutomationService --> NotificationService
BG --> AutomationService
NotificationService --> Mongo

QuizRouter --> Auth : utilisateur courant
MatchingRouter --> Auth : utilisateur courant
AccountRouter --> Auth : utilisateur courant
@enduml
