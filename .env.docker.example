# ---------------------------------------------------------------------------
# Compose-interpolated variables (frontend build args + a few runtime knobs).
# Copy to .env  ->  cp .env.docker.example .env
#
# Backend SECRETS live separately in backend/.env (see backend/copy.env).
# ---------------------------------------------------------------------------

# URL the browser uses to reach the backend. For local Docker use the default;
# for a remote deployment set this to the public backend URL (e.g. https://api.example.com).
VITE_API_URL=http://localhost:8000

# Public URL the frontend is served from (used by Vite host checks / WebRTC).
VITE_FRONTEND_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080

# Supabase (public, safe to expose in the client bundle).
VITE_SUPABASE_URL=https://jjkgikxzoyuiostwurqd.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_k3_Ud4WP5YiXNqr2_bXNPw_uV8qHR0b

# Where the backend reaches Ollama. Default assumes Ollama runs on the Docker host.
# For a remote GPU box: http://your-ollama-host:11434/api
OLLAMA_BASE_URL=http://host.docker.internal:11434/api

# Optional TURN server for WebRTC (leave empty to use the public relay fallback).
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
