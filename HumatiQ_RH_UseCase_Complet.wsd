@startuml HumatiQ_RH_UseCase_Complet
skinparam backgroundColor #F8FAFC
skinparam defaultFontName Arial
skinparam actor {
  BackgroundColor #2D3748
  FontColor white
  BorderColor #6C63FF
}
skinparam usecase {
  BackgroundColor #EBF8FF
  BorderColor #3182CE
}

left to right direction

' ── ACTEURS ─────────────────────
actor "Admin/ARH"              as ARH
actor "Recruteur"              as REC
actor "Chef Département"       as CHEF
actor "Candidat"               as CAND
actor "IA Engine <<System>>"   as AI
actor "Google Calendar"        as GCal
actor "Email System"           as EMAIL

ARH --|> REC
CHEF --|> REC

' ════════════════════════════════
' MODULE 1 — Authentification
' ════════════════════════════════
rectangle "1. Authentification & Profil RH" {
  usecase "Se connecter Email/Pass"    as UC1_1
  usecase "Se connecter Google/LinkedIn" as UC1_2
  usecase "Se déconnecter"             as UC1_3
  usecase "Réinitialiser mot de passe" as UC1_4
  usecase "Vérifier email (OTP)"       as UC1_5
  usecase "Configurer profil RH"       as UC1_6
  usecase "Gérer préférences"          as UC1_7
  usecase "Connecter Google Calendar"  as UC1_8
}
ARH -- UC1_1 : ARH/REC/CHEF
ARH -- UC1_2
ARH -- UC1_3
ARH -- UC1_4
ARH -- UC1_5
ARH -- UC1_6
ARH -- UC1_7
ARH -- UC1_8
UC1_8 ..> GCal : <<include>>

' ════════════════════════════════
' MODULE 2 — Offres d'Emploi
' ════════════════════════════════
rectangle "2. Gestion des Offres d'Emploi" {
  usecase "Créer une offre"             as UC2_1
  usecase "Modifier une offre"          as UC2_2
  usecase "Supprimer une offre"         as UC2_3
  usecase "Consulter toutes les offres" as UC2_4
  usecase "Filtrer par département"     as UC2_5
  usecase "Voir stats de l'offre"       as UC2_6
  usecase "Gérer les départements"      as UC2_7
}
ARH -- UC2_1
ARH -- UC2_2
ARH -- UC2_3
ARH -- UC2_4
ARH -- UC2_5
ARH -- UC2_6
ARH -- UC2_7
UC2_5 ..> UC2_4 : <<extend>>
UC2_6 ..> UC2_4 : <<extend>>

' ════════════════════════════════
' MODULE 3 — Pipeline Candidatures
' ════════════════════════════════
rectangle "3. Pipeline de Candidatures" {
  usecase "Voir candidatures (Kanban)"       as UC3_1
  usecase "Changer statut candidature"       as UC3_2
  usecase "Profil 360° du candidat"          as UC3_3
  usecase "Télécharger le CV"                as UC3_4
  usecase "Voir snapshot candidature"        as UC3_5
  usecase "Supprimer candidature"            as UC3_6
  usecase "Voir score IA pertinence"         as UC3_7
  usecase "Voir justification IA"            as UC3_8
  usecase "Filtrer par statut"               as UC3_9
  usecase "Réinitialiser candidature"        as UC3_10
}
ARH -- UC3_1
ARH -- UC3_2
ARH -- UC3_3
ARH -- UC3_4
ARH -- UC3_5
ARH -- UC3_6
ARH -- UC3_7
ARH -- UC3_8
ARH -- UC3_9
ARH -- UC3_10
UC3_7 ..> UC3_3 : <<include>>
UC3_8 ..> UC3_7 : <<extend>>

' ════════════════════════════════
' MODULE 4 — Évaluation & Notation
' ════════════════════════════════
rectangle "4. Évaluation & Notation HR" {
  usecase "Attribuer note 1-5★"               as UC4_1
  usecase "Modifier notation"                  as UC4_2
  usecase "Voir note moyenne (multi-RH)"       as UC4_3
  usecase "Vérifier qualification Expérience"  as UC4_4
  usecase "Vérifier qualification Formation"   as UC4_5
  usecase "Vérifier qualification Certificat"  as UC4_6
  usecase "Télécharger preuve qualification"   as UC4_7
  usecase "Ajouter note de vérification"       as UC4_8
}
ARH -- UC4_1
ARH -- UC4_2
ARH -- UC4_3
ARH -- UC4_4
ARH -- UC4_5
ARH -- UC4_6
ARH -- UC4_7
ARH -- UC4_8
UC4_2 ..> UC4_1 : <<extend>>
UC4_4 ..> UC4_7 : <<extend>>
UC4_5 ..> UC4_7 : <<extend>>
UC4_6 ..> UC4_7 : <<extend>>

' ════════════════════════════════
' MODULE 5 — Quiz IA
' ════════════════════════════════
rectangle "5. Génération de Quiz IA" {
  usecase "Uploader document référence"     as UC5_1
  usecase "Générer quiz mono-document"      as UC5_2
  usecase "Générer quiz multi-documents"    as UC5_3
  usecase "Prévisualiser questions"         as UC5_4
  usecase "Modifier questions du quiz"      as UC5_5
  usecase "Ajouter question à la volée"     as UC5_6
  usecase "Publier quiz au candidat"        as UC5_7
  usecase "Archiver un quiz"                as UC5_8
  usecase "Vérifier existence quiz"         as UC5_9
  usecase "Consulter résultats quiz"        as UC5_10
  usecase "Voir analyse IA résultats"       as UC5_11
}
ARH -- UC5_1
ARH -- UC5_2
ARH -- UC5_3
ARH -- UC5_4
ARH -- UC5_5
ARH -- UC5_6
ARH -- UC5_7
ARH -- UC5_8
ARH -- UC5_9
ARH -- UC5_10
ARH -- UC5_11
UC5_2 ..> AI : <<include>>
UC5_3 ..> AI : <<include>>
UC5_5 ..> UC5_4 : <<extend>>
UC5_7 ..> EMAIL : <<include>>
UC5_11 ..> AI : <<include>>

' ════════════════════════════════
' MODULE 6 — Entretiens
' ════════════════════════════════
rectangle "6. Planification & Conduite d'Entretiens" {
  usecase "Proposer créneaux entretien"       as UC6_1
  usecase "Créer entretien directement"       as UC6_2
  usecase "Modifier entretien"                as UC6_3
  usecase "Annuler/Supprimer entretien"       as UC6_4
  usecase "Voir entretiens société"           as UC6_5
  usecase "Voir créneaux occupés"             as UC6_6
  usecase "Synchroniser Google Calendar"      as UC6_7
  usecase "Démarrer session vidéo WebRTC"     as UC6_8
  usecase "Terminer entretien"                as UC6_9
  usecase "Voir transcription temps réel"     as UC6_10
  usecase "Analyser émotions IA temps réel"   as UC6_11
  usecase "Générer rapport IA post-entretien" as UC6_12
  usecase "Consulter rapport IA entretien"    as UC6_13
  usecase "Voir historique entretiens"        as UC6_14
}
ARH -- UC6_1
ARH -- UC6_2
ARH -- UC6_3
ARH -- UC6_4
ARH -- UC6_5
ARH -- UC6_6
ARH -- UC6_7
ARH -- UC6_8
ARH -- UC6_9
ARH -- UC6_10
ARH -- UC6_11
ARH -- UC6_12
ARH -- UC6_13
ARH -- UC6_14
UC6_1 ..> EMAIL : <<include>>
UC6_6 ..> UC6_1 : <<include>>
UC6_7 ..> GCal : <<include>>
UC6_11 ..> AI : <<include>>
UC6_12 ..> AI : <<include>>

' ════════════════════════════════
' MODULE 7 — Notifications
' ════════════════════════════════
rectangle "7. Notifications & Alertes" {
  usecase "Recevoir alerte nouvelle candidature" as UC7_1
  usecase "Recevoir rapport performance"         as UC7_2
  usecase "Recevoir confirmation créneau"        as UC7_3
  usecase "Recevoir rappel entretien 24h/1h"     as UC7_4
  usecase "Consulter centre notifications"       as UC7_5
  usecase "Marquer notifications lues"           as UC7_6
}
ARH -- UC7_1
ARH -- UC7_2
ARH -- UC7_3
ARH -- UC7_4
ARH -- UC7_5
ARH -- UC7_6
UC7_4 ..> EMAIL : <<include>>

' ════════════════════════════════
' MODULE 8 — Analytics
' ════════════════════════════════
rectangle "8. Analytics & Tableau de Bord" {
  usecase "Voir KPIs société"                  as UC8_1
  usecase "Voir distribution par département"  as UC8_2
  usecase "Voir tendance candidatures 30j"     as UC8_3
  usecase "Voir score IA moyen"                as UC8_4
  usecase "Voir top profils score 90+"         as UC8_5
}
ARH -- UC8_1
ARH -- UC8_2
ARH -- UC8_3
ARH -- UC8_4
ARH -- UC8_5

@enduml