<?xml version="1.0" encoding="UTF-8"?>
<definitions
  xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0"
  xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0"
  id="Definitions_HumatiQ"
  targetNamespace="http://humatiq.io/bpmn/2026"
  exporter="HumatiQ BPMN Generator v1.0">

  <!-- ═══════════════════════════════════════════════════════
       COLLABORATION
  ════════════════════════════════════════════════════════ -->
  <collaboration id="Collab_HumatiQ">
    <participant id="Pool_Main" name="Processus de Recrutement — HumatiQ" processRef="Process_Main"/>
  </collaboration>

  <!-- ═══════════════════════════════════════════════════════
       MAIN PROCESS
  ════════════════════════════════════════════════════════ -->
  <process id="Process_Main" name="Recrutement HumatiQ" isExecutable="false">

    <laneSet id="LaneSet_1">

      <!-- LANE 1 : RH / RECRUTEUR -->
      <lane id="Lane_RH" name="RH / Recruteur (Admin · ARH · Chef Dept.)">
        <flowNodeRef>Start_1</flowNodeRef>
        <flowNodeRef>Task_CreateJob</flowNodeRef>
        <flowNodeRef>Task_PublishJob</flowNodeRef>
        <flowNodeRef>Catch_AppReceived</flowNodeRef>
        <flowNodeRef>Task_ReviewApp</flowNodeRef>
        <flowNodeRef>Gateway_AcceptApp</flowNodeRef>
        <flowNodeRef>Task_Reject1</flowNodeRef>
        <flowNodeRef>End_Rejected1</flowNodeRef>
        <flowNodeRef>Task_EditQuiz</flowNodeRef>
        <flowNodeRef>Task_PublishQuiz</flowNodeRef>
        <flowNodeRef>Task_ReviewQuizResult</flowNodeRef>
        <flowNodeRef>Gateway_QuizOK</flowNodeRef>
        <flowNodeRef>Task_Reject2</flowNodeRef>
        <flowNodeRef>End_Rejected2</flowNodeRef>
        <flowNodeRef>Task_ProposeSlots</flowNodeRef>
        <flowNodeRef>Catch_SlotConfirmed</flowNodeRef>
        <flowNodeRef>Task_CreateInterview</flowNodeRef>
        <flowNodeRef>Timer_WaitInterview</flowNodeRef>
        <flowNodeRef>Task_ConductInterview</flowNodeRef>
        <flowNodeRef>Task_ReviewReport</flowNodeRef>
        <flowNodeRef>Gateway_FinalDecision</flowNodeRef>
        <flowNodeRef>Task_SendOffer</flowNodeRef>
        <flowNodeRef>End_Hired</flowNodeRef>
        <flowNodeRef>Task_Reject3</flowNodeRef>
        <flowNodeRef>End_Rejected3</flowNodeRef>
      </lane>

      <!-- LANE 2 : CANDIDAT -->
      <lane id="Lane_Candidat" name="Candidat">
        <flowNodeRef>Task_FindJob</flowNodeRef>
        <flowNodeRef>Task_Apply</flowNodeRef>
        <flowNodeRef>Task_TakeQuiz</flowNodeRef>
        <flowNodeRef>Task_ChooseSlot</flowNodeRef>
        <flowNodeRef>Task_JoinInterview</flowNodeRef>
      </lane>

      <!-- LANE 3 : SYSTÈMES IA & EXTERNES -->
      <lane id="Lane_IA" name="Système IA · Email · Google Calendar">
        <flowNodeRef>Task_ScoreCV</flowNodeRef>
        <flowNodeRef>Task_GenerateQuiz</flowNodeRef>
        <flowNodeRef>Task_EmailQuizNotif</flowNodeRef>
        <flowNodeRef>Task_AnalyzeQuiz</flowNodeRef>
        <flowNodeRef>Task_EmailSlots</flowNodeRef>
        <flowNodeRef>Task_SyncCalendar</flowNodeRef>
        <flowNodeRef>Task_EmailConfirm</flowNodeRef>
        <flowNodeRef>Task_AnalyzeEmotions</flowNodeRef>
        <flowNodeRef>Task_GenerateReport</flowNodeRef>
        <flowNodeRef>Task_EmailFinal</flowNodeRef>
      </lane>

    </laneSet>

    <!-- ─────────────────────────────────────────────────────
         START
    ───────────────────────────────────────────────────── -->
    <startEvent id="Start_1" name="Besoin de recrutement&#10;identifié">
      <outgoing>sf_1</outgoing>
    </startEvent>

    <!-- ─────────────────────────────────────────────────────
         PHASE 1 — GESTION DES OFFRES D'EMPLOI
    ───────────────────────────────────────────────────── -->
    <userTask id="Task_CreateJob" name="Créer l'offre d'emploi&#10;(titre, compétences, département)">
      <documentation>L'ARH crée une nouvelle offre avec : titre du poste, description, compétences requises, département, type de contrat, localisation, salaire.</documentation>
      <incoming>sf_1</incoming>
      <outgoing>sf_2</outgoing>
    </userTask>

    <userTask id="Task_PublishJob" name="Publier l'offre sur&#10;la plateforme HumatiQ">
      <documentation>L'offre devient visible aux candidats sur le portail. Elle est indexée et peut être filtrée par département, type de contrat, etc.</documentation>
      <incoming>sf_2</incoming>
      <outgoing>sf_3</outgoing>
    </userTask>

    <!-- ─────────────────────────────────────────────────────
         PHASE 2 — CANDIDATURE
    ───────────────────────────────────────────────────── -->
    <userTask id="Task_FindJob" name="Consulter les offres&#10;disponibles">
      <documentation>Le candidat recherche et filtre les offres d'emploi disponibles sur le portail HumatiQ.</documentation>
      <incoming>sf_3</incoming>
      <outgoing>sf_4</outgoing>
    </userTask>

    <userTask id="Task_Apply" name="Postuler&#10;(CV + lettre de motivation)">
      <documentation>Le candidat soumet sa candidature : CV uploadé, lettre de motivation, snapshot du profil. Une notification est envoyée automatiquement au RH.</documentation>
      <incoming>sf_4</incoming>
      <outgoing>sf_5</outgoing>
    </userTask>

    <intermediateCatchEvent id="Catch_AppReceived" name="Candidature reçue&#10;(notification)">
      <documentation>Le système notifie l'équipe RH qu'une nouvelle candidature est disponible pour traitement.</documentation>
      <incoming>sf_5</incoming>
      <outgoing>sf_6</outgoing>
      <messageEventDefinition id="MsgDef_AppReceived"/>
    </intermediateCatchEvent>

    <!-- ─────────────────────────────────────────────────────
         PHASE 3 — TRAITEMENT CANDIDATURE (IA + RH)
    ───────────────────────────────────────────────────── -->
    <serviceTask id="Task_ScoreCV" name="Parser CV &amp; calculer&#10;score IA (0-100)">
      <documentation>L'IA HumatiQ analyse le CV : extraction de compétences, calcul d'un score de pertinence, génération d'une justification textuelle. Modèle : AI Matching Engine.</documentation>
      <incoming>sf_6</incoming>
      <outgoing>sf_7</outgoing>
    </serviceTask>

    <userTask id="Task_ReviewApp" name="Consulter candidature&#10;+ score IA + profil 360°">
      <documentation>Le recruteur consulte la candidature enrichie : score IA, justification, CV, profil complet du candidat, historique des candidatures, qualifications vérifiées.</documentation>
      <incoming>sf_7</incoming>
      <outgoing>sf_8</outgoing>
    </userTask>

    <exclusiveGateway id="Gateway_AcceptApp" name="Candidature&#10;pertinente ?">
      <incoming>sf_8</incoming>
      <outgoing>sf_9_yes</outgoing>
      <outgoing>sf_9_no</outgoing>
    </exclusiveGateway>

    <task id="Task_Reject1" name="Envoyer notification&#10;de refus (phase 1)">
      <incoming>sf_9_no</incoming>
      <outgoing>sf_10</outgoing>
    </task>
    <endEvent id="End_Rejected1" name="Candidature refusée&#10;(score insuffisant)">
      <incoming>sf_10</incoming>
      <terminateEventDefinition/>
    </endEvent>

    <!-- ─────────────────────────────────────────────────────
         PHASE 4 — GÉNÉRATION ET PASSAGE DU QUIZ IA
    ───────────────────────────────────────────────────── -->
    <serviceTask id="Task_GenerateQuiz" name="Générer quiz IA&#10;(depuis documents RH)">
      <documentation>L'IA génère automatiquement un quiz (QCM + Vrai/Faux) à partir de documents RH uploadés. Paramètres : nombre de questions, difficulté (facile/moyen/difficile), sections filtrées.</documentation>
      <incoming>sf_9_yes</incoming>
      <outgoing>sf_11</outgoing>
    </serviceTask>

    <userTask id="Task_EditQuiz" name="Éditer, valider et&#10;configurer le quiz">
      <documentation>Le recruteur révise les questions générées, peut ajouter/supprimer/modifier des questions, configure le timer (en minutes), puis valide le quiz.</documentation>
      <incoming>sf_11</incoming>
      <outgoing>sf_12</outgoing>
    </userTask>

    <sendTask id="Task_PublishQuiz" name="Publier quiz au candidat&#10;(statut: publié)">
      <documentation>Le quiz est publié avec le statut 'published' et lié à la candidature. Le candidat reçoit une notification in-app et par email.</documentation>
      <incoming>sf_12</incoming>
      <outgoing>sf_13</outgoing>
    </sendTask>

    <serviceTask id="Task_EmailQuizNotif" name="Email &amp; notification in-app&#10;— Quiz disponible">
      <documentation>Le système envoie automatiquement un email et une notification in-app au candidat : lien vers le quiz, durée, instructions.</documentation>
      <incoming>sf_13</incoming>
      <outgoing>sf_14</outgoing>
    </serviceTask>

    <userTask id="Task_TakeQuiz" name="Passer le quiz en ligne&#10;(avec timer automatique)">
      <documentation>Le candidat accède au quiz depuis son espace, démarre le timer, répond aux questions (QCM + V/F) et soumet ses réponses avant expiration du timer.</documentation>
      <incoming>sf_14</incoming>
      <outgoing>sf_15</outgoing>
    </userTask>

    <serviceTask id="Task_AnalyzeQuiz" name="Analyser résultats quiz (IA)&#10;+ calcul score final">
      <documentation>L'IA calcule le score du quiz, identifie les lacunes, génère un rapport d'analyse détaillé. Les résultats sont stockés dans la candidature.</documentation>
      <incoming>sf_15</incoming>
      <outgoing>sf_16</outgoing>
    </serviceTask>

    <userTask id="Task_ReviewQuizResult" name="Consulter résultats du quiz&#10;et analyse IA">
      <documentation>Le recruteur consulte le score, les réponses détaillées, l'analyse IA des lacunes et les recommandations. Score visible dans la fiche candidat.</documentation>
      <incoming>sf_16</incoming>
      <outgoing>sf_17</outgoing>
    </userTask>

    <exclusiveGateway id="Gateway_QuizOK" name="Candidat qualifié&#10;après quiz ?">
      <incoming>sf_17</incoming>
      <outgoing>sf_18_yes</outgoing>
      <outgoing>sf_18_no</outgoing>
    </exclusiveGateway>

    <task id="Task_Reject2" name="Notifier refus&#10;après quiz">
      <incoming>sf_18_no</incoming>
      <outgoing>sf_19</outgoing>
    </task>
    <endEvent id="End_Rejected2" name="Refusé après quiz">
      <incoming>sf_19</incoming>
      <terminateEventDefinition/>
    </endEvent>

    <!-- ─────────────────────────────────────────────────────
         PHASE 5 — PLANIFICATION DE L'ENTRETIEN
    ───────────────────────────────────────────────────── -->
    <userTask id="Task_ProposeSlots" name="Proposer des créneaux&#10;d'entretien disponibles">
      <documentation>Le recruteur sélectionne des créneaux horaires disponibles (vérification anti-doublon), choisit le type d'entretien (vidéo/présentiel), rédige un message personnalisé.</documentation>
      <incoming>sf_18_yes</incoming>
      <outgoing>sf_20</outgoing>
    </userTask>

    <serviceTask id="Task_EmailSlots" name="Email invitation candidat&#10;avec créneaux disponibles">
      <documentation>Le système envoie automatiquement un email au candidat avec la liste des créneaux disponibles, le type d'entretien, et un lien de confirmation.</documentation>
      <incoming>sf_20</incoming>
      <outgoing>sf_21</outgoing>
    </serviceTask>

    <userTask id="Task_ChooseSlot" name="Choisir un créneau&#10;d'entretien">
      <documentation>Le candidat consulte les créneaux proposés depuis son espace et sélectionne celui qui lui convient. Une notification de confirmation est envoyée au recruteur.</documentation>
      <incoming>sf_21</incoming>
      <outgoing>sf_22</outgoing>
    </userTask>

    <intermediateCatchEvent id="Catch_SlotConfirmed" name="Créneau confirmé&#10;par le candidat">
      <incoming>sf_22</incoming>
      <outgoing>sf_23</outgoing>
      <messageEventDefinition id="MsgDef_SlotConfirmed"/>
    </intermediateCatchEvent>

    <userTask id="Task_CreateInterview" name="Créer l'entretien&#10;dans le système">
      <documentation>Le recruteur crée l'entretien officiel avec : date/heure, type, durée, candidat lié, candidature liée. L'entretien obtient un identifiant unique et une salle WebRTC.</documentation>
      <incoming>sf_23</incoming>
      <outgoing>sf_24</outgoing>
    </userTask>

    <serviceTask id="Task_SyncCalendar" name="Synchroniser&#10;Google Calendar">
      <documentation>Le système synchronise automatiquement l'entretien avec le Google Calendar du recruteur via OAuth2. Un événement est créé avec les détails et les participants.</documentation>
      <incoming>sf_24</incoming>
      <outgoing>sf_25</outgoing>
    </serviceTask>

    <serviceTask id="Task_EmailConfirm" name="Email de confirmation&#10;aux deux parties (+ rappels)">
      <documentation>Emails de confirmation envoyés au recruteur et au candidat avec la date, l'heure, le type d'entretien. Des rappels automatiques sont planifiés à 24h et 1h avant.</documentation>
      <incoming>sf_25</incoming>
      <outgoing>sf_26</outgoing>
      <outgoing>sf_26b</outgoing>
    </serviceTask>

    <intermediateCatchEvent id="Timer_WaitInterview" name="Attendre la date&#10;de l'entretien">
      <incoming>sf_26</incoming>
      <outgoing>sf_27</outgoing>
      <timerEventDefinition id="TimerDef_1"/>
    </intermediateCatchEvent>

    <!-- ─────────────────────────────────────────────────────
         PHASE 6 — CONDUITE DE L'ENTRETIEN (VIDÉO + IA)
    ───────────────────────────────────────────────────── -->
    <userTask id="Task_ConductInterview" name="Conduire l'entretien&#10;vidéo (WebRTC)">
      <documentation>Le recruteur rejoint la salle WebRTC dédiée, conduit l'entretien vidéo en temps réel. Fonctionnalités : caméra/micro, chat, transcription automatique (Speech-to-Text).</documentation>
      <incoming>sf_27</incoming>
      <outgoing>sf_28</outgoing>
    </userTask>

    <userTask id="Task_JoinInterview" name="Rejoindre l'entretien&#10;vidéo (WebRTC)">
      <documentation>Le candidat accède à la salle WebRTC via son espace. La connexion peer-to-peer est établie automatiquement via les signaux WebSocket.</documentation>
      <incoming>sf_26b</incoming>
      <outgoing>sf_28b</outgoing>
    </userTask>

    <serviceTask id="Task_AnalyzeEmotions" name="Analyser émotions en&#10;temps réel (IA — FER model)">
      <documentation>Le moteur IA analyse les expressions faciales du candidat frame par frame (modèle FER). Les résultats (émotions : joie, stress, confiance, etc.) sont stockés avec timestamps.</documentation>
      <incoming>sf_28</incoming>
      <incoming>sf_28b</incoming>
      <outgoing>sf_29</outgoing>
    </serviceTask>

    <serviceTask id="Task_GenerateReport" name="Générer rapport IA&#10;post-entretien (analyse complète)">
      <documentation>L'IA génère un rapport complet : analyse de la transcription, courbe des émotions, points forts/faibles, recommandation globale, score de l'entretien.</documentation>
      <incoming>sf_29</incoming>
      <outgoing>sf_30</outgoing>
    </serviceTask>

    <!-- ─────────────────────────────────────────────────────
         PHASE 7 — DÉCISION FINALE
    ───────────────────────────────────────────────────── -->
    <userTask id="Task_ReviewReport" name="Consulter rapport IA&#10;de l'entretien (360°)">
      <documentation>Le recruteur consulte le rapport IA complet : transcription, analyse émotionnelle, recommandations, score global. Il peut aussi noter manuellement le candidat (1-5 étoiles).</documentation>
      <incoming>sf_30</incoming>
      <outgoing>sf_31</outgoing>
    </userTask>

    <exclusiveGateway id="Gateway_FinalDecision" name="Décision finale ?">
      <incoming>sf_31</incoming>
      <outgoing>sf_32_hired</outgoing>
      <outgoing>sf_32_rejected</outgoing>
    </exclusiveGateway>

    <task id="Task_SendOffer" name="Préparer et envoyer&#10;l'offre d'emploi">
      <documentation>Le recruteur prépare l'offre officielle : conditions, salaire, date de démarrage. L'offre est envoyée au candidat par email.</documentation>
      <incoming>sf_32_hired</incoming>
      <outgoing>sf_33</outgoing>
    </task>

    <serviceTask id="Task_EmailFinal" name="Email : Offre acceptée /&#10;Refus final + notification">
      <documentation>Le système envoie l'email final (offre ou refus) et déclenche toutes les notifications in-app correspondantes. La candidature est archivée avec le statut final.</documentation>
      <incoming>sf_33</incoming>
      <incoming>sf_34</incoming>
      <outgoing>sf_35_hired</outgoing>
      <outgoing>sf_35_rejected</outgoing>
    </serviceTask>

    <endEvent id="End_Hired" name="✅ Candidat embauché">
      <incoming>sf_35_hired</incoming>
    </endEvent>

    <task id="Task_Reject3" name="Envoyer refus final&#10;et archiver candidature">
      <incoming>sf_32_rejected</incoming>
      <outgoing>sf_34</outgoing>
    </task>

    <endEvent id="End_Rejected3" name="❌ Candidat refusé">
      <incoming>sf_35_rejected</incoming>
      <terminateEventDefinition/>
    </endEvent>

    <!-- ═══════════════════════════════════════════════════════
         SEQUENCE FLOWS — LIENS ENTRE ÉLÉMENTS
    ════════════════════════════════════════════════════════ -->

    <!-- Phase 1 : Offre -->
    <sequenceFlow id="sf_1"  sourceRef="Start_1"           targetRef="Task_CreateJob"/>
    <sequenceFlow id="sf_2"  sourceRef="Task_CreateJob"    targetRef="Task_PublishJob"/>
    <sequenceFlow id="sf_3"  sourceRef="Task_PublishJob"   targetRef="Task_FindJob"/>

    <!-- Phase 2 : Candidature -->
    <sequenceFlow id="sf_4"  sourceRef="Task_FindJob"      targetRef="Task_Apply"/>
    <sequenceFlow id="sf_5"  sourceRef="Task_Apply"        targetRef="Catch_AppReceived"/>

    <!-- Phase 3 : Traitement -->
    <sequenceFlow id="sf_6"  sourceRef="Catch_AppReceived" targetRef="Task_ScoreCV"/>
    <sequenceFlow id="sf_7"  sourceRef="Task_ScoreCV"      targetRef="Task_ReviewApp"/>
    <sequenceFlow id="sf_8"  sourceRef="Task_ReviewApp"    targetRef="Gateway_AcceptApp"/>
    <sequenceFlow id="sf_9_yes" name="✔ Pertinente"        sourceRef="Gateway_AcceptApp" targetRef="Task_GenerateQuiz"/>
    <sequenceFlow id="sf_9_no"  name="✘ Non pertinente"    sourceRef="Gateway_AcceptApp" targetRef="Task_Reject1"/>
    <sequenceFlow id="sf_10" sourceRef="Task_Reject1"      targetRef="End_Rejected1"/>

    <!-- Phase 4 : Quiz -->
    <sequenceFlow id="sf_11" sourceRef="Task_GenerateQuiz"    targetRef="Task_EditQuiz"/>
    <sequenceFlow id="sf_12" sourceRef="Task_EditQuiz"        targetRef="Task_PublishQuiz"/>
    <sequenceFlow id="sf_13" sourceRef="Task_PublishQuiz"     targetRef="Task_EmailQuizNotif"/>
    <sequenceFlow id="sf_14" sourceRef="Task_EmailQuizNotif"  targetRef="Task_TakeQuiz"/>
    <sequenceFlow id="sf_15" sourceRef="Task_TakeQuiz"        targetRef="Task_AnalyzeQuiz"/>
    <sequenceFlow id="sf_16" sourceRef="Task_AnalyzeQuiz"     targetRef="Task_ReviewQuizResult"/>
    <sequenceFlow id="sf_17" sourceRef="Task_ReviewQuizResult" targetRef="Gateway_QuizOK"/>
    <sequenceFlow id="sf_18_yes" name="✔ Qualifié"           sourceRef="Gateway_QuizOK" targetRef="Task_ProposeSlots"/>
    <sequenceFlow id="sf_18_no"  name="✘ Non qualifié"       sourceRef="Gateway_QuizOK" targetRef="Task_Reject2"/>
    <sequenceFlow id="sf_19" sourceRef="Task_Reject2"         targetRef="End_Rejected2"/>

    <!-- Phase 5 : Planification -->
    <sequenceFlow id="sf_20" sourceRef="Task_ProposeSlots"    targetRef="Task_EmailSlots"/>
    <sequenceFlow id="sf_21" sourceRef="Task_EmailSlots"      targetRef="Task_ChooseSlot"/>
    <sequenceFlow id="sf_22" sourceRef="Task_ChooseSlot"      targetRef="Catch_SlotConfirmed"/>
    <sequenceFlow id="sf_23" sourceRef="Catch_SlotConfirmed"  targetRef="Task_CreateInterview"/>
    <sequenceFlow id="sf_24" sourceRef="Task_CreateInterview" targetRef="Task_SyncCalendar"/>
    <sequenceFlow id="sf_25" sourceRef="Task_SyncCalendar"    targetRef="Task_EmailConfirm"/>
    <sequenceFlow id="sf_26"  sourceRef="Task_EmailConfirm"   targetRef="Timer_WaitInterview"/>
    <sequenceFlow id="sf_26b" sourceRef="Task_EmailConfirm"   targetRef="Task_JoinInterview"/>

    <!-- Phase 6 : Entretien -->
    <sequenceFlow id="sf_27"  sourceRef="Timer_WaitInterview" targetRef="Task_ConductInterview"/>
    <sequenceFlow id="sf_28"  sourceRef="Task_ConductInterview" targetRef="Task_AnalyzeEmotions"/>
    <sequenceFlow id="sf_28b" sourceRef="Task_JoinInterview"  targetRef="Task_AnalyzeEmotions"/>
    <sequenceFlow id="sf_29"  sourceRef="Task_AnalyzeEmotions" targetRef="Task_GenerateReport"/>
    <sequenceFlow id="sf_30"  sourceRef="Task_GenerateReport"  targetRef="Task_ReviewReport"/>

    <!-- Phase 7 : Décision -->
    <sequenceFlow id="sf_31" sourceRef="Task_ReviewReport"    targetRef="Gateway_FinalDecision"/>
    <sequenceFlow id="sf_32_hired"    name="✔ Embauché"       sourceRef="Gateway_FinalDecision" targetRef="Task_SendOffer"/>
    <sequenceFlow id="sf_32_rejected" name="✘ Refusé"         sourceRef="Gateway_FinalDecision" targetRef="Task_Reject3"/>
    <sequenceFlow id="sf_33" sourceRef="Task_SendOffer"       targetRef="Task_EmailFinal"/>
    <sequenceFlow id="sf_34" sourceRef="Task_Reject3"         targetRef="Task_EmailFinal"/>
    <sequenceFlow id="sf_35_hired"    sourceRef="Task_EmailFinal" targetRef="End_Hired"/>
    <sequenceFlow id="sf_35_rejected" sourceRef="Task_EmailFinal" targetRef="End_Rejected3"/>

  </process>

  <!-- ═══════════════════════════════════════════════════════
       DIAGRAM INTERCHANGE (DI) — POSITIONS VISUELLES
  ════════════════════════════════════════════════════════ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collab_HumatiQ">

      <!-- POOL -->
      <bpmndi:BPMNShape id="Shape_Pool" bpmnElement="Pool_Main" isHorizontal="true">
        <dc:Bounds x="130" y="50" width="3420" height="660"/>
      </bpmndi:BPMNShape>

      <!-- LANE RH -->
      <bpmndi:BPMNShape id="Shape_Lane_RH" bpmnElement="Lane_RH" isHorizontal="true">
        <dc:Bounds x="160" y="50" width="3390" height="220"/>
      </bpmndi:BPMNShape>

      <!-- LANE CANDIDAT -->
      <bpmndi:BPMNShape id="Shape_Lane_Candidat" bpmnElement="Lane_Candidat" isHorizontal="true">
        <dc:Bounds x="160" y="270" width="3390" height="220"/>
      </bpmndi:BPMNShape>

      <!-- LANE IA -->
      <bpmndi:BPMNShape id="Shape_Lane_IA" bpmnElement="Lane_IA" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="3390" height="220"/>
      </bpmndi:BPMNShape>

      <!-- ── START ── -->
      <bpmndi:BPMNShape id="Shape_Start_1" bpmnElement="Start_1">
        <dc:Bounds x="222" y="142" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="202" y="185" width="79" height="40"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ── PHASE 1 : OFFRE ── -->
      <bpmndi:BPMNShape id="Shape_CreateJob" bpmnElement="Task_CreateJob">
        <dc:Bounds x="310" y="120" width="130" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_PublishJob" bpmnElement="Task_PublishJob">
        <dc:Bounds x="490" y="120" width="130" height="80"/>
      </bpmndi:BPMNShape>

      <!-- ── PHASE 2 : CANDIDATURE ── -->
      <bpmndi:BPMNShape id="Shape_FindJob" bpmnElement="Task_FindJob">
        <dc:Bounds x="490" y="340" width="130" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Apply" bpmnElement="Task_Apply">
        <dc:Bounds x="670" y="340" width="130" height="80"/>
      </bpmndi:BPMNShape>
